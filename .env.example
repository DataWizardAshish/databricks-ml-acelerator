# Copy to .env and fill in values.
# Auth: PAT is read from ~/.databrickscfg DEFAULT profile automatically.
# Only override here if you want to bypass the profile.

DATABRICKS_HOST=https://<workspace>.azuredatabricks.net
# DATABRICKS_TOKEN=your-pat-here  (or use secret scope below)

# Cluster to attach for Spark (databricks-connect)
DATABRICKS_CLUSTER_ID=<cluster-id>

# LLM endpoint name (Databricks serving endpoint)
LLM_ENDPOINT_NAME=<llm-endpoint-name>

# Unity Catalog
UC_CATALOG=<catalog>
UC_DISCOVERY_SCHEMA=<discovery-schema>
UC_OUTPUT_SCHEMA=ml_accelerator

# Auth type: pat | oauth  (oauth = future)
AUTH_TYPE=pat

# Secret scope (used in Databricks Apps to retrieve PAT at runtime)
DATABRICKS_SECRET_SCOPE=<secret-scope-name>
DATABRICKS_SECRET_KEY=<secret-key-name>
