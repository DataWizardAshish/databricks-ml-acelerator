# Copy to .env and fill in values.
# Auth: PAT is read from ~/.databrickscfg DEFAULT profile automatically.
# Only override here if you want to bypass the profile.

# DATABRICKS_HOST=https://adidas-dwhm-lh-wrk-gazelle-dev.cloud.databricks.com/
# DATABRICKS_TOKEN=your-pat-here

# Cluster to attach for Spark (databricks-connect)
DATABRICKS_CLUSTER_ID=1217-094102-xswsfzua

# LLM endpoint name (Databricks serving endpoint)
LLM_ENDPOINT_NAME=ds-brand-funnel-ai_claude-sonnet-4-5_chat_dev

# Unity Catalog
UC_CATALOG=lakehouse_dev
UC_DISCOVERY_SCHEMA=ds_brand_funnel_ai_lhdev
UC_OUTPUT_SCHEMA=ml_accelerator

# Auth type: pat | oauth  (oauth = future)
AUTH_TYPE=pat
